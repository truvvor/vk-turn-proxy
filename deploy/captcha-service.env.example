# Config for captcha-service.service
# Copy to /etc/vk-turn-proxy/captcha-service.env (install.sh generates
# this file with a fresh API_KEY on first install).

LISTEN_ADDR=:18080
# API_KEY is the bearer token the iOS client must send in `Authorization:
# Bearer <API_KEY>` on every /cred request. Treat it like a password.
API_KEY=changeme
