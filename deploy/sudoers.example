# Allow the GitHub Actions self-hosted runner user to deploy vk-turn-proxy
# without a password prompt. Replace 'github-runner' with the user that runs
# the runner service.
#
# Install with:
#   sudo install -m 0440 -o root -g root deploy/sudoers.example /etc/sudoers.d/vk-turn-proxy-runner
#   sudo visudo -cf /etc/sudoers.d/vk-turn-proxy-runner

github-runner ALL=(root) NOPASSWD: /usr/bin/install -m 0755 -o root -g root * /opt/vk-turn-proxy/server.new
github-runner ALL=(root) NOPASSWD: /bin/mv -f /opt/vk-turn-proxy/server.new /opt/vk-turn-proxy/server
github-runner ALL=(root) NOPASSWD: /bin/systemctl restart vk-turn-proxy@*.service
github-runner ALL=(root) NOPASSWD: /bin/systemctl is-enabled vk-turn-proxy@*.service
github-runner ALL=(root) NOPASSWD: /bin/systemctl is-active vk-turn-proxy@*.service
