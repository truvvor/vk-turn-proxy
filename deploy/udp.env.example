# Config for vk-turn-proxy@udp.service (WireGuard / UDP forwarding)
# Copy to /etc/vk-turn-proxy/udp.env and edit CONNECT.

LISTEN=0.0.0.0:56000
CONNECT=127.0.0.1:51820

# EXTRA_ARGS options:
#   -aggregate
#     Aggregate N DTLS streams per client into a single backend UDP socket.
#     Each DTLS stream must send a 16-byte session ID right after the
#     handshake. WIRE-INCOMPATIBLE with clients that don't speak the
#     protocol. Only turn on when every client supports it.
EXTRA_ARGS=
